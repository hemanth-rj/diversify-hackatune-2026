# ─── Sounds Like You — server environment template ───────────────────────────
# Copy to .env and fill in real values.  NEVER commit .env to git.
# On the server this file lives at:
#   /home/ekin/mml-hackatune-26/discovery/.env
# and is loaded by systemd via EnvironmentFile=.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL — includes pgvector (vec_mel, vec_chroma, vec_mfcc, vec_tonnetz)
#              and all Cyanite tags / track metadata.
DATABASE_URL=postgresql://USER:PASS@HOST:5432/DBNAME

# Gemini 2.5 Flash — used by Chat (intent parsing) and MoodBoard (vision+intent).
# Without this key both tabs return HTTP 500. Taste / Similar / Insights still work.
GEMINI_API_KEY=

# Cyanite REST API — only needed if you re-run compute_learned_weights.py
# or idf.py (both call the Cyanite tagging API to fetch model outputs).
# The live webapp does NOT call Cyanite at runtime; all tags are in Postgres.
CYANITE_API_KEY=
CYANITE_ACCOUNT=

# ─── Server-inferred paths (not env vars, documented here for reference) ─────
#
# Audio corpus (50 k MP3s, served at /audio/{jamendo_id}.mp3):
#   ~/mml-hackatune-26/harvester/corpus/audio/
#   Detected automatically by data_loader.py; falls back to Jamendo CDN if absent.
#
# Rust query binary (used by /api/similar-file via subprocess):
#   ~/mml-hackatune-26/harvester/target/release/query
#   Built with: cd ~/mml-hackatune-26/harvester && cargo build --release --bin query
#
# Learned weights (86-dim, produced by compute_learned_weights.py):
#   ~/mml-hackatune-26/data/learned_weights.json
#   Falls back to IDF weights if file is absent.
#
# Python venv:
#   /home/ekin/mml-hackatune-26/webapp/venv/
#
# systemd service:
#   sudo systemctl {start|stop|restart|status} slu-discovery
#   Logs: sudo journalctl -u slu-discovery -f
#
# Live URL:
#   http://95.xxx.xx.x61:8001
